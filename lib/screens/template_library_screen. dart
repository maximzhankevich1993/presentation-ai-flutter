// MAIN SCREEN
// ═══════════════════════════════════════════════════════════════════════════════
class TemplateLibraryScreen extends ConsumerStatefulWidget {
  const TemplateLibraryScreen({super.key});

  @override
  ConsumerState<TemplateLibraryScreen> createState() => _TemplateLibraryScreenState();
}

class _TemplateLibraryScreenState extends ConsumerState<TemplateLibraryScreen> {
  final ScrollController _scrollController = ScrollController();
  final List<String> _categoryNames = [
    'Все', 'Популярное', 'Бизнес', 'Маркетинг', 'Образование', 'Отчёты', 'Личные'
  ];
  final List<TemplateCategory> _categoryValues = [
    TemplateCategory.all, TemplateCategory.popular, TemplateCategory.business,
    TemplateCategory.marketing, TemplateCategory.education, TemplateCategory.reports,
    TemplateCategory.personal,
  ];

  @override
  void initState() {
    super.initState();
    _scrollController.addListener(() {
      if (_scrollController.position.pixels >=
          _scrollController.position.maxScrollExtent - 300) {
        ref.read(templatesProvider.notifier).loadMore();
      }
    });
  }

  @override
  void dispose() {
    _scrollController.dispose();
    super.dispose();
  }

  void _onSearch(String value) {
    ref.read(searchProvider.notifier).state = value;
  }

  void _useTemplate(Template template) {
    // Создаём презентацию из шаблона
    final presentation = Presentation(
      id: DateTime.now().toString(),
      title: template.title,
      slides: [
        Slide(
          title: template.title,
          content: [template.description],
        ),
      ],
      createdAt: DateTime.now(),
    );
    
    // Открываем редактор ПОЛНОЭКРАННО (не снизу)
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (_) => EditorScreen(presentation: presentation),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    final templates = ref.watch(filteredProvider);
    final controller = ref.watch(templatesProvider.notifier);
    final selectedCategory = ref.watch(categoryProvider);

    return Scaffold(
      backgroundColor: _T.bgBase,
      appBar: AppBar(
        backgroundColor: _T.bgBase,
        elevation: 0,
        leading: IconButton(
          icon: const Icon(Icons.arrow_back_ios_rounded, color: Colors.white),
          onPressed: () => Navigator.pop(context),
        ),
        title: const Text(
          'Шаблоны',
          style: TextStyle(color: Colors.white, fontSize: 20, fontWeight: FontWeight.w700),
        ),
        centerTitle: true,
      ),
      body: Column(
        children: [
          // Поиск
          Padding(
            padding: const EdgeInsets.fromLTRB(16, 16, 16, 8),
            child: Container(
              decoration: BoxDecoration(
                color: _T.bgCard,
                borderRadius: BorderRadius.circular(14),
                border: Border.all(color: const Color(0xFF2A2A2A)),
              ),
              child: TextField(
                onChanged: _onSearch,
                style: const TextStyle(color: Colors.white),
                decoration: InputDecoration(
                  hintText: 'Быстрый поиск по шаблонам',
                  hintStyle: const TextStyle(color: _T.txtMuted),
                  prefixIcon: const Icon(Icons.search_rounded, color: _T.accent),
                  border: InputBorder.none,
                  contentPadding: const EdgeInsets.symmetric(horizontal: 16, vertical: 14),
                ),
              ),
            ),
          ),
          // Категории
          SizedBox(
            height: 44,
            child: ListView.builder(
              scrollDirection: Axis.horizontal,
              padding: const EdgeInsets.symmetric(horizontal: 12),
              itemCount: _categoryNames.length,
              itemBuilder: (_, i) {
                final isSelected = _categoryValues[i] == selectedCategory;
                return Padding(
                  padding: const EdgeInsets.symmetric(horizontal: 4),
                  child: MouseRegion(
                    cursor: SystemMouseCursors.click,
                    child: GestureDetector(
                      onTap: () => ref.read(categoryProvider.notifier).state = _categoryValues[i],
                      child: AnimatedContainer(
                        duration: const Duration(milliseconds: 200),
                        padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                        decoration: BoxDecoration(
                          color: isSelected ? _T.accent : _T.bgCard,
                          borderRadius: BorderRadius.circular(24),
                          border: Border.all(
                            color: isSelected ? Colors.transparent : const Color(0xFF2A2A2A),
                          ),
                        ),
                        child: Text(
                          _categoryNames[i],
                          style: TextStyle(
                            color: isSelected ? Colors.white : _T.txtSecondary,
                            fontSize: 13,
                            fontWeight: isSelected ? FontWeight.w600 : FontWeight.w400,
                          ),
                        ),
                      ),
                    ),
                  ),
                );
              },
            ),
          ),
          const SizedBox(height: 8),
          // Список шаблонов
          Expanded(
            child: RefreshIndicator(
              onRefresh: controller.refresh,
              color: _T.accent,
              child: templates.isEmpty
                  ? Center(
                      child: Column(
                        mainAxisAlignment: MainAxisAlignment.center,
                        children: [
                          Icon(Icons.search_off_rounded, size: 48, color: _T.txtMuted),
                          const SizedBox(height: 12),
                          Text(
                            'Ничего не найдено',
                            style: TextStyle(color: _T.txtSecondary, fontSize: 14),
                          ),
                        ],
                      ),
                    )
                  : GridView.builder(
                      controller: _scrollController,
                      padding: const EdgeInsets.all(16),
                      gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
                        crossAxisCount: 2,
                        crossAxisSpacing: 12,
                        mainAxisSpacing: 12,
                        childAspectRatio: 0.85,
                      ),
                      itemCount: templates.length + 2,
                      itemBuilder: (_, i) {
                        if (i >= templates.length) {
                          return const _SkeletonCard();
                        }
                        final template = templates[i];
                        return _TemplateCard(
                          template: template,
                          onTap: () => _useTemplate(template),
                        );
                      },
                    ),
            ),
          ),
        ],
      ),
    );
  }
}

