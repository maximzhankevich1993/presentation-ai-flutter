// STATE (RIVERPOD)
// ═══════════════════════════════════════════════════════════════════════════════
final searchProvider = StateProvider<String>((ref) => '');
final categoryProvider = StateProvider<TemplateCategory>((ref) => TemplateCategory.all);

final templatesProvider = StateNotifierProvider<TemplateController, List<Template>>(
  (ref) => TemplateController(ref, _allTemplates),
);

class TemplateController extends StateNotifier<List<Template>> {
  TemplateController(this.ref, this._allTemplates) : super([]) {
    _loadMore();
  }

  final Ref ref;
  final List<Template> _allTemplates;
  int _page = 0;
  bool _loading = false;
  bool _hasMore = true;
  static const int _limit = 12;

  bool get hasMore => _hasMore;

  Future<void> _loadMore() async {
    if (_loading || !_hasMore) return;

    _loading = true;

    final start = _page * _limit;
    if (start >= _allTemplates.length) {
      _hasMore = false;
    } else {
      final end = (start + _limit) > _allTemplates.length ? _allTemplates.length : start + _limit;
      final newItems = _allTemplates.sublist(start, end);
      _page++;
      state = [...state, ...newItems];
    }

    _loading = false;
  }

  Future<void> loadMore() async => _loadMore();

  Future<void> refresh() async {
    _page = 0;
    _hasMore = true;
    state = [];
    await _loadMore();
  }
}

final filteredProvider = Provider<List<Template>>((ref) {
  final list = ref.watch(templatesProvider);
  final query = ref.watch(searchProvider).toLowerCase();
  final category = ref.watch(categoryProvider);

  return list.where((t) {
    final matchSearch = query.isEmpty ||
        t.title.toLowerCase().contains(query) ||
        t.description.toLowerCase().contains(query);

    final matchCategory = category == TemplateCategory.all ||
        (category == TemplateCategory.popular && t.isPopular) ||
        t.category == category;

    return matchSearch && matchCategory;
  }).toList();
});

