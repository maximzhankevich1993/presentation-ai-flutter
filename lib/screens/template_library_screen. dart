import 'dart:convert';
import 'package:flutter/services.dart';
import '../models/template.dart';
import 'api_service.dart';

class TemplateService {
  static List<Template> _cachedFreeTemplates = [];
  static List<Template> _cachedPremiumTemplates = [];
  
  // Загрузка бесплатных шаблонов с сервера
  static Future<List<Template>> loadFreeTemplates() async {
    if (_cachedFreeTemplates.isNotEmpty) {
      return _cachedFreeTemplates;
    }
    
    try {
      final response = await ApiService.get('/templates/free');
      if (response['success'] == true) {
        final List<dynamic> templatesJson = response['templates'];
        _cachedFreeTemplates = templatesJson.map((j) => Template.fromJson(j)).toList();
        return _cachedFreeTemplates;
      }
      return [];
    } catch (e) {
      print('Error loading free templates: $e');
      return [];
    }
  }
  
  // Загрузка премиум шаблонов с сервера
  static Future<List<Template>> loadPremiumTemplates() async {
    if (_cachedPremiumTemplates.isNotEmpty) {
      return _cachedPremiumTemplates;
    }
    
    try {
      final response = await ApiService.get('/templates/premium');
      if (response['success'] == true) {
        final List<dynamic> templatesJson = response['templates'];
        _cachedPremiumTemplates = templatesJson.map((j) => Template.fromJson(j)).toList();
        return _cachedPremiumTemplates;
      }
      return [];
    } catch (e) {
      print('Error loading premium templates: $e');
      return [];
    }
  }
  
  // Загрузка всех шаблонов
  static Future<List<Template>> loadAllTemplates({bool includePremium = false}) async {
    final free = await loadFreeTemplates();
    if (!includePremium) return free;
    
    final premium = await loadPremiumTemplates();
    return [...free, ...premium];
  }
  
  // Создание нового шаблона
  static Future<Template?> createTemplate(Template template) async {
    try {
      final response = await ApiService.post('/templates', data: template.toJson());
      if (response['success'] == true) {
        final newTemplate = Template.fromJson(response['template']);
        _cachedPremiumTemplates.insert(0, newTemplate);
        return newTemplate;
      }
      return null;
    } catch (e) {
      print('Error creating template: $e');
      return null;
    }
  }
  
  // Удаление шаблона
  static Future<bool> deleteTemplate(String id) async {
    try {
      final response = await ApiService.delete('/templates/$id');
      if (response['success'] == true) {
        _cachedPremiumTemplates.removeWhere((t) => t.id == id);
        return true;
      }
      return false;
    } catch (e) {
      print('Error deleting template: $e');
      return false;
    }
  }
}