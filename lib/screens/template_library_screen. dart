import 'package:provider/provider.dart';
import '../models/template.dart';
import '../models/presentation.dart';
import '../providers/user_provider.dart';
import '../services/template_service.dart';
import 'editor_screen.dart';
import 'loading_screen.dart';

class TemplateLibraryScreen extends StatefulWidget {
  const TemplateLibraryScreen({super.key});

  @override
  State<TemplateLibraryScreen> createState() => _TemplateLibraryScreenState();
}

class _TemplateLibraryScreenState extends State<TemplateLibraryScreen> {
  String _searchQuery = '';
  String _selectedCategory = 'Все';
  bool _isLoading = true;
  List<Template> _allTemplates = [];
  List<Template> _filteredTemplates = [];

  final List<String> _categories = [
    'Все', 'Популярное', 'Бизнес', 'Образование', 'Маркетинг', 'Отчёты', 'Личные'
  ];

  @override
  void initState() {
    super.initState();
    _loadTemplates();
  }

  Future<void> _loadTemplates() async {
    setState(() => _isLoading = true);
    
    try {
      final up = Provider.of<UserProvider>(context, listen: false);
      final includePremium = up.isPremium;
      
      final templates = await TemplateService.loadAllTemplates(includePremium: includePremium);
      
      setState(() {
        _allTemplates = templates;
        _filteredTemplates = templates;
        _isLoading = false;
      });
    } catch (e) {
      setState(() => _isLoading = false);
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Ошибка загрузки шаблонов: $e'),
            backgroundColor: const Color(0xFFFF3B30),
          ),
        );
      }
    }
  }

  void _filterTemplates() {
    setState(() {
      _filteredTemplates = _allTemplates.where((t) {
        final matchesSearch = _searchQuery.isEmpty ||
            t.title.toLowerCase().contains(_searchQuery.toLowerCase()) ||
            t.description.toLowerCase().contains(_searchQuery.toLowerCase());
        
        final matchesCategory = _selectedCategory == 'Все' || 
            (_selectedCategory == 'Популярное' ? t.isPopular : t.category == _selectedCategory);
        
        return matchesSearch && matchesCategory;
      }).toList();
    });
  }

  void _updateSearch(String query) {
    _searchQuery = query;
    _filterTemplates();
  }

  void _updateCategory(String category) {
    _selectedCategory = category;
    _filterTemplates();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFF121212),
      appBar: AppBar(
        backgroundColor: const Color(0xFF121212),
        elevation: 0,
        leading: IconButton(
          icon: const Icon(Icons.arrow_back_ios_rounded, color: Colors.white),
          onPressed: () => Navigator.pop(context),
        ),
        title: const Text(
          'Шаблоны',
          style: TextStyle(color: Colors.white, fontSize: 20, fontWeight: FontWeight.w700),
        ),
        centerTitle: true,
      ),
      body: _isLoading
          ? const Center(child: CircularProgressIndicator(color: Color(0xFF1DB954)))
          : Column(
              children: [
                // Поиск
                Padding(
                  padding: const EdgeInsets.fromLTRB(16, 16, 16, 8),
                  child: Container(
                    decoration: BoxDecoration(
                      color: const Color(0xFF1E1E1E),
                      borderRadius: BorderRadius.circular(14),
                      border: Border.all(color: const Color(0xFF2A2A2A)),
                    ),
                    child: TextField(
                      onChanged: _updateSearch,
                      style: const TextStyle(color: Colors.white),
                      decoration: InputDecoration(
                        hintText: 'Быстрый поиск по шаблонам',
                        hintStyle: const TextStyle(color: Color(0xFF4A4A4A)),
                        prefixIcon: const Icon(Icons.search_rounded, color: Color(0xFF1DB954)),
                        border: InputBorder.none,
                        contentPadding: const EdgeInsets.symmetric(horizontal: 16, vertical: 14),
                        suffixIcon: _searchQuery.isNotEmpty
                            ? IconButton(
                                icon: const Icon(Icons.close_rounded, color: Color(0xFF4A4A4A)),
                                onPressed: () => _updateSearch(''),
                              )
                            : null,
                      ),
                    ),
                  ),
                ),
                // Категории
                SizedBox(
                  height: 44,
                  child: ListView.builder(
                    scrollDirection: Axis.horizontal,
                    padding: const EdgeInsets.symmetric(horizontal: 12),
                    itemCount: _categories.length,
                    itemBuilder: (_, i) {
                      final cat = _categories[i];
                      final isSelected = _selectedCategory == cat;
                      return Padding(
                        padding: const EdgeInsets.symmetric(horizontal: 4),
                        child: MouseRegion(
                          cursor: SystemMouseCursors.click,
                          child: GestureDetector(
                            onTap: () => _updateCategory(cat),
                            child: AnimatedContainer(
                              duration: const Duration(milliseconds: 200),
                              padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                              decoration: BoxDecoration(
                                color: isSelected ? const Color(0xFF1DB954) : const Color(0xFF1E1E1E),
                                borderRadius: BorderRadius.circular(24),
                                border: Border.all(
                                  color: isSelected ? Colors.transparent : const Color(0xFF2A2A2A),
                                ),
                              ),
                              child: Text(
                                cat,
                                style: TextStyle(
                                  color: isSelected ? Colors.white : const Color(0xFF9A9A9A),
                                  fontSize: 13,
                                  fontWeight: isSelected ? FontWeight.w600 : FontWeight.w400,
                                ),
                              ),
                            ),
                          ),
                        ),
                      );
                    },
                  ),
                ),
                const SizedBox(height: 8),
                // Список шаблонов
                Expanded(
                  child: _filteredTemplates.isEmpty
                      ? Center(
                          child: Column(
                            mainAxisAlignment: MainAxisAlignment.center,
                            children: [
                              Icon(Icons.search_off_rounded, size: 48, color: const Color(0xFF4A4A4A)),
                              const SizedBox(height: 12),
                              const Text(
                                'Ничего не найдено',
                                style: TextStyle(color: Color(0xFF9A9A9A), fontSize: 14),
                              ),
                            ],
                          ),
                        )
                      : ListView.builder(
                          padding: const EdgeInsets.all(16),
                          itemCount: _filteredTemplates.length,
                          itemBuilder: (_, i) => _TemplateCard(
                            template: _filteredTemplates[i],
                            onTap: () => _useTemplate(_filteredTemplates[i]),
                          ),
                        ),
                ),
              ],
            ),
    );
  }

  void _useTemplate(Template template) async {
    setState(() => _isLoading = true);
    
    try {
      final presentation = _createPresentationFromTemplate(template);
      
      if (!mounted) return;
      
      Navigator.pushReplacement(
        context,
        MaterialPageRoute(
          builder: (_) => EditorScreen(presentation: presentation),
        ),
      );
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Ошибка загрузки шаблона: $e'),
            backgroundColor: const Color(0xFFFF3B30),
          ),
        );
      }
    } finally {
      if (mounted) setState(() => _isLoading = false);
    }
  }

  Presentation _createPresentationFromTemplate(Template template) {
    final List<Slide> slides = [];
    
    if (template.slides.isEmpty) {
      slides.add(Slide(
        title: template.title,
        content: [template.description],
      ));
    } else {
      for (final slideData in template.slides) {
        slides.add(Slide(
          title: slideData['title'] ?? '',
          content: List<String>.from(slideData['content'] ?? []),
        ));
      }
    }
    
    return Presentation(
      id: DateTime.now().toString(),
      title: template.title,
      slides: slides,
      createdAt: DateTime.now(),
    );
  }
}

